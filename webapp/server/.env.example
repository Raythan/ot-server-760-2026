# --- MySQL: alinhar com `server/config.lua` (TFS) quando for o mesmo servidor/banco ---
# config.lua          ->  variável no .env da API
# mysqlHost            ->  MYSQL_HOST
# mysqlPort            ->  MYSQL_PORT
# mysqlUser            ->  MYSQL_USER
# mysqlPass            ->  MYSQL_PASSWORD  (ou MYSQL_PASS, mesmo valor)
# mysqlDatabase        ->  MYSQL_DATABASE
#
# Windows (XAMPP / MariaDB) + API Node na mesma máquina:
#   Prefira MYSQL_HOST=localhost (named pipe). Com 127.0.0.1 o mysql2 pode falhar com ER_ACCESS_DENIED.
# TFS no WSL acessando MySQL no Windows: no config.lua use o IP do host (ex.: 172.x), não confunda com este .env.
#
# Copie usuário/senha/base iguais ao que o MySQL realmente aceita (root com senha, ou usuário dedicado com GRANT em tibia.*).

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
# MYSQL_PASS=

MYSQL_DATABASE=tibia

# API
PORT=3847
HOST=0.0.0.0

JWT_SECRET=change-me-long-random-string

CORS_ORIGIN=true

RATE_LIMIT_MAX=120
RATE_LIMIT_REGISTER=15
RATE_LIMIT_LOGIN=30
RATE_LIMIT_FORGOT_PASSWORD=10
RATE_LIMIT_RESET_PASSWORD=20

# Redefinição de senha — ver README (SMTP, Resend ou Web3Forms)
WEBAPP_PUBLIC_URL=http://localhost:5173
# PASSWORD_RESET_TTL_SEC=3600

# Transporte: smtp | resend | web3forms | none (omitir = auto: SMTP_HOST → RESEND_API_KEY → WEB3FORMS)
# EMAIL_TRANSPORT=smtp

# --- SMTP (ex.: Brevo gratuito, Gmail com senha de app) ---
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM="Tenebra OT <noreply@seudominio.com>"

# --- Resend (API) ---
# RESEND_API_KEY=re_...
# RESEND_FROM="Tenebra OT <onboarding@resend.dev>"

# --- Web3Forms (legado / testes) ---
# WEB3FORMS_ACCESS_KEY=
# WEB3FORMS_FROM_NAME=Tenebra OT — Contas
# WEB3FORMS_CCEMAIL_TO_SUBMITTER=0

# API_DEBUG=1
