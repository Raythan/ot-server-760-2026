# Alinhar estes valores entre a API (Node) e o proxy de desenvolvimento do Vite.
# Copia as linhas relevantes para:
#   webapp/server/.env   → PORT, e opcionalmente CORS_ORIGIN
#   webapp/client/.env   → VITE_DEV_* (só para `npm run dev` no cliente)
#
# Em desenvolvimento, o browser fala só com o Vite (ex.: localhost:5173); o Vite
# encaminha /api para a API abaixo — mesmo origem no browser → sem problema de CORS.
#
# API (servidor Node)
PORT=3847
HOST=0.0.0.0
#
# Cliente Vite (proxy /api → API)
VITE_DEV_API_HOST=127.0.0.1
VITE_DEV_API_PORT=3847
VITE_DEV_CLIENT_PORT=5173
#
# CORS da API (só quando o site e a API são origens diferentes, ex. build estático noutro URL)
# true = reflectir a origem do pedido; em localhost com proxy não é necessário mudar.
# CORS_ORIGIN=true
