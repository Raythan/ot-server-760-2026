__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# --- Node (webapp e futuros pacotes na raiz) ---
node_modules/
webapp/**/dist/

# Segredos locais (API / cliente)
.env
.env.local

# Chaves / credenciais locais (pasta dedicada)
chaves/
