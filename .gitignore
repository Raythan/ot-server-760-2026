# --- Build (CMake / compilado) ---
server/build/
**/CMakeFiles/
**/cmake_install.cmake
**/CMakeCache.txt
**/Makefile
**/*.o
**/*.a
**/*.so.dbg
compile_commands.json

# Binário do servidor (gerado em build/)
server/build/tfs
server/tfs

# --- Logs e PIDs em runtime ---
server/logs/*.log
server/logs/*.pid
*.log

# --- Arquivos compactados / dumps locais ---
*.zip
*.7z
*.rar

# --- Cliente OT (cópia local completa; não versionar) ---
